{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://methodology.local/schema/context.schema.json",
  "title": ".ai/context.json — L0 Portable Boot Context",
  "description": "어떤 AI 모델·어떤 PC에서든 저장소 하나로 부팅 가능하게 하는 정형 컨텍스트. 10_foundation/WHITEPAPER.md §5 L0 참조.",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "current_phase",
    "last_session",
    "must_read"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "context.json 자체의 스키마 버전. 마이그레이션 식별용."
    },
    "schema_url": {
      "type": "string",
      "pattern": "^(?!/).+",
      "description": "이 인스턴스를 검증할 수 있는 스키마 파일 경로 (저장소 상대)."
    },
    "project": {
      "type": "object",
      "required": ["name", "kind"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["methodology-source", "applied-project"],
          "description": "methodology-source: 본 방법론 자체 저장소. applied-project: 방법론을 적용한 일반 프로젝트."
        },
        "domain": {
          "type": "string",
          "minLength": 1,
          "description": "도메인 식별자 (예: webapp-next, data-pipeline, slack-bot, meta)."
        },
        "started_on": {
          "type": "string",
          "format": "date",
          "description": "프로젝트 시작일(YYYY-MM-DD)."
        }
      }
    },
    "current_phase": {
      "type": "object",
      "required": ["stage", "label"],
      "additionalProperties": false,
      "properties": {
        "stage": { "type": "string", "minLength": 1, "description": "WHITEPAPER §10 단계 ID (stage-1 ~ stage-5)." },
        "label": { "type": "string", "minLength": 1 },
        "since": { "type": "string", "format": "date" }
      }
    },
    "active_skeleton": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["id", "version"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        }
      ],
      "description": "이 프로젝트에 적용된 Skeleton (없으면 null)."
    },
    "last_session": {
      "type": "object",
      "required": ["ended_at", "agent", "checkpoint_file"],
      "additionalProperties": false,
      "properties": {
        "ended_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC. 로컬 시간대 금지."
        },
        "agent": {
          "type": "object",
          "required": ["model"],
          "additionalProperties": false,
          "properties": {
            "model": { "type": "string", "minLength": 1, "description": "예: claude-sonnet-4-6, gpt-5, gemini-2.5-pro." },
            "tool": { "type": "string", "minLength": 1, "description": "예: claude-code-cli, cursor, codex-cli, web-ui." },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "host_os": {
          "type": "string",
          "minLength": 1,
          "description": "환경 이식성 추적용. 예: darwin-25.4, linux-6.5, win-wsl2."
        },
        "checkpoint_file": {
          "type": "string",
          "pattern": "^(?!/).+",
          "description": "이 세션이 남긴 인계서 경로. 보통 .ai/checkpoint.md."
        }
      }
    },
    "must_read": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(?!/).+" },
      "description": "신규 AI가 부팅 시 반드시 읽어야 하는 파일 목록 (저장소 상대 경로). 순서대로 읽힘을 가정."
    },
    "must_read_optional": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(?!/).+" },
      "description": "작업 성격에 따라 추가로 읽으면 좋은 파일들."
    },
    "active_todos": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9]{1,8}-\\d{3}$" },
      "description": "진행 중 TODO ID 목록 (예: META-001)."
    },
    "active_catalog_hits": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^C-\\d{3}$" },
      "description": "이 프로젝트가 의존하는 Catalog 엔트리 ID (예: C-014)."
    },
    "adapters_present": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "description": ".ai/adapters/ 아래 존재하는 어댑터 이름 목록 (확장자 제외)."
    }
  }
}
