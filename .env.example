# Supabase — 새 API 키 체계(publishable/secret). legacy anon/service_role은 2026년 말까지 병행 지원되나
# 신규 프로젝트는 새 키를 쓴다. Dashboard > Settings > API Keys 에서 발급.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# AI 크롤 분석 (lib/ai/claude.ts) — 미설정 시 fail-closed로 크롤 분석 폐기
ANTHROPIC_API_KEY=

# Vercel Cron 인증 (vercel.json의 /api/crawl, /api/admin/bot-activity)
CRON_SECRET=

# Google Tag Manager — Production 환경에만 설정할 것 (Preview 미설정 시 GTM 자체가 렌더되지 않음)
NEXT_PUBLIC_GTM_ID=
